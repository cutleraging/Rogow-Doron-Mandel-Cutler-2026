## Dicer1

### Scramble vs dCAS9
```{r}
setwd(paste0(working.dir, "4-differential-expression"))

# differential expression
dicer_scramble_vs_dcas9 <- de_report(dds,
                                    contrast = c("condition", "scramble_dicer", "dcas_dicer"),
                                    alpha = 0.05,
                                    fc_cutoff = 2,
                                    max_labels_per_direction = 10,
                                    annot_cols = c("gene_name","entrezid","gene_biotype","description"),
                                    label_col   = "gene_name",
                                    top_annotation_cols = c("group","type"),
                                    results_csv = "dicer_scramble_vs_dcas9.csv",
                                    plots_pdf   = "dicer_scramble_vs_dcas9.pdf")

# biotype dsitribution
test_biotype_distribution(dicer_scramble_vs_dcas9$res_df,
                          biotype_col = "gene_biotype",
                          padj_col = "padj",
                          lfc_col = "log2FoldChange",
                          alpha = 0.05,
                          fc_cutoff = 0,
                          drop_biotypes = c(NA, "", "unknown", "Unknown"),
                          min_biotype_count = 10,
                          pdf_file = "dicer_scramble_vs_dcas9_biotype.pdf",
                          csv_file = "dicer_scramble_vs_dcas9_biotype.csv")
```

