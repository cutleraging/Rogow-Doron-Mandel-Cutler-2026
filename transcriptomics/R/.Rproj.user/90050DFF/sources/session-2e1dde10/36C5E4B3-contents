## Interaction DICER1 and EXOSC4 KD
- Tests whether sex alters the effect of the diet
```{r}
setwd(paste0(working.dir, "4-differential-expression"))

# set levels
se.filter$group <- factor(se.filter$group, levels=c("neg", "dicer", "malt", "pos"))
se.filter$type <- factor(se.filter$type, levels=c("scramble","dcas9", "guide2", "guide3"))

# interaction design
dds <- DESeqDataSet(se.filter, design = ~ group * type)

dds <- DESeq(dds)

resultsNames(dds)

# get results
dicer_vs_exosc4_interaction <- results(dds, 
                  alpha = 0.05, 
                  name = "groupdicer.typeguide2")

# get a summary of the amount of significantly DEG 
summary(dicer_vs_exosc4_interaction, 
        alpha = 0.05)

# get shrunken fold change
# dicer_vs_exosc4_interaction <- lfcShrink(dds = dds,
#                               res = dicer_vs_exosc4_interaction,
#                               contrast = c("condition", "no infect", "background"),
