## Differential abundance

### Fit linear model
```{r}
setwd(paste0(working.dir, "6-differential-expression-pathway"))

# Create the design matrix
design <- model.matrix(~ sex * diet, data = colData(dds))

# make names in correct format=
colnames(design) <- make.names(colnames(design))

# Fit the linear model
fit <- lmFit(se.filter.gsva, design)

# Compute empirical Bayes statistics
fit.eb <- eBayes(fit, robust=TRUE)

gssizes <- sapply(se.filter.param@geneSets, length)
gssizes <- gssizes[rownames(se.filter.gsva)]
all(names(gssizes) == names(fit.eb$sigma))

pdf("gene_set_size_vs_precision.pdf",
    width = 5,
    height = 5)
plot(sqrt(gssizes), sqrt(fit.eb$sigma), xlab="Sqrt(gene sets sizes)",
          ylab="Sqrt(standard deviation)", las=1, pch=".", cex=4)
lines(lowess(sqrt(gssizes), sqrt(fit.eb$sigma)), col="red", lwd=2)
dev.off()

# account for increased precision of larger gene sets using limma trend
fit.eb.trend <- eBayes(fit, robust=TRUE, trend=gssizes)

# set up contrasts
contrasts <- makeContrasts(
  # Diet effect in males: (MHF - MNC) = diethigh.fat coefficient
  Diet_Male       = diethigh.fat,

  # Diet effect in females: (FHF - FNC) = diethigh.fat + interaction
  Diet_Female     = diethigh.fat + sexfemale.diethigh.fat,

  # Sex effect in normal chow: (FNC - MNC) = sexfemale coefficient
  Sex_NC          = sexfemale,

  # Sex effect in high fat: (FHF - MHF) = sexfemale + interaction
  Sex_HF          = sexfemale + sexfemale.diethigh.fat,

  # Interaction: (Diet_Female - Diet_Male) = interaction coefficient
  Interaction     = sexfemale.diethigh.fat,

  levels = colnames(design)
)

# Apply the contrasts to the fit object
fit.eb.trend <- contrasts.fit(fit.eb.trend, contrasts)

# Re-compute the empirical Bayes statistics for this specific contrast
fit.eb.trend <- eBayes(fit.eb.trend, robust=TRUE, trend=gssizes)

results.adjusted <- summary(decideTests(fit.eb.trend,
                    adjust.method = 'BH',
                    p.value = 0.05,
                    lfc = 0.5))
write.csv(results.adjusted, "summary_expression_abundance_pathway_lfc1_pvalue0.05.csv")
