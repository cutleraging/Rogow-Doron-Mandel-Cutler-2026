## Load data
```{r}
setwd(paste0(working.dir, "1-data"))

# tpm
tpm <- read.table('rsem.merged.gene_tpm.tsv', header = TRUE, row.names = 1)
tpm$transcript_id.s. <- NULL

# Reformat column names
clean <- sub("^X", "", colnames(tpm))        # drop leading “X”
clean <- gsub("\\.", "-", clean)             # turn every “.” into “-”
colnames(tpm) <- clean

# Keep only columns that appear in metadata
keep <- intersect(colnames(tpm), metadata$sample)
tpm_filtered <- tpm[, keep]

# reorder columns
tpm_filtered <- tpm[, metadata$sample[metadata$sample %in% colnames(tpm)]]

# counts
counts <- read.table('rsem.merged.gene_counts.tsv', header = TRUE, row.names = 1)
counts$transcript_id.s. <- NULL

# Reformat column names
clean <- sub("^X", "", colnames(counts))        # drop leading “X”
clean <- gsub("\\.", "-", clean)             # turn every “.” into “-”
colnames(counts) <- clean

# Keep only columns that appear in metadata
keep <- intersect(colnames(counts), metadata$sample)
counts_filtered <- counts[, keep]

# reorder columns
counts_filtered <- counts[, metadata$sample[metadata$sample %in% colnames(counts)]]

se <- SummarizedExperiment(assays=SimpleList(counts = as.matrix(round(counts_filtered)),
                                             tpm = as.matrix(tpm_filtered)),
                                             colData = metadata)

# remove version from gene name
rownames(se) <- lapply(rownames(se), sub, pattern = "\\.\\d+$", replacement = "")
```

