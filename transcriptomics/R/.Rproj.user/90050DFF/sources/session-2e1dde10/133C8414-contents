diet_vs_sex_interaction_merge <- merge(diet_vs_sex_interaction_merge, 
                        diet_vs_sex_interaction[,c("ensembl_gene_id", "log2FoldChange", "pvalue", "padj")],
                        by = "ensembl_gene_id")

# clean up columns
diet_vs_sex_interaction_merge <- diet_vs_sex_interaction_merge[c("ensembl_gene_id", "external_gene_name",
                                   "log2FoldChange.x", "pvalue.x", "padj.x",
                                   "log2FoldChange.y", "pvalue.y", "padj.y",
                                   "log2FoldChange", "pvalue", "padj")]

# rename columns
colnames(diet_vs_sex_interaction_merge)[3:11] <- c("male_high.fat_vs_male_normal.logFC",
                                    "male_high.fat_vs_male_normal.P.Value",
                                    "male_high.fat_vs_male_normal.adj.P.Val",
                                    "female_high.fat_vs_female_normal.logFC",
                                    "female_high.fat_vs_female_normal.P.Value",
                                    "female_high.fat_vs_female_normal.adj.P.Val",
                                    "diet_vs_sex_interaction_merge.logFC",
                                    "diet_vs_sex_interaction_merge.P.Value",
                                    "diet_vs_sex_interaction_merge.adj.P.Val")

fc_thr    <- 1
p_thr     <- 0.05
delta_thr <- 0.1

diet_vs_sex_interaction_merge <- diet_vs_sex_interaction_merge %>%
  mutate(
    x = male_high.fat_vs_male_normal.logFC,
    y = female_high.fat_vs_female_normal.logFC,
    delta = diet_vs_sex_interaction_merge.logFC,
    quadrant = case_when(
      x > 0 & y > 0 ~ "Concordant Up",
      x < 0 & y < 0 ~ "Concordant Down",
      x > 0 & y < 0 ~ "Negative Reversal: Up -> Down",
      x < 0 & y > 0 ~ "Positive Reversal: Down -> Up",
      TRUE ~ "Near Zero / Mixed"
    ),
    modulation = case_when(
      quadrant == "Concordant Up"   & delta >  delta_thr ~ "Amplified Up",
      quadrant == "Concordant Up"   & delta < -delta_thr ~ "Attenuated Up",
      quadrant == "Concordant Down" & delta < -delta_thr ~ "Amplified Down",
      quadrant == "Concordant Down" & delta >  delta_thr ~ "Attenuated Down",
      TRUE ~ NA_character_
    ),
    sig_int = !is.na(diet_vs_sex_interaction_merge.adj.P.Val) &
              diet_vs_sex_interaction_merge.adj.P.Val < p_thr,
    sig_simple = ((abs(x) > fc_thr) & !is.na(male_high.fat_vs_male_normal.adj.P.Val) &
                   male_high.fat_vs_male_normal.adj.P.Val < p_thr) |
                 ((abs(y) > fc_thr) & !is.na(female_high.fat_vs_female_normal.adj.P.Val) &
                   female_high.fat_vs_female_normal.adj.P.Val < p_thr),
    Label = case_when(
      sig_int    ~ if_else(!is.na(modulation), modulation, quadrant),
      sig_simple ~ if_else(!is.na(modulation), modulation, quadrant),
      TRUE       ~ "Not Significant"
    )
  )

table(diet_vs_sex_interaction_merge$modulation)

# output
write.csv(diet_vs_sex_interaction_merge, "diet_vs_sex_interaction_merge.csv", row.names = FALSE)

## ---- plot ----

