## Male High-Fat vs Male Normal
```{r}
setwd(paste0(working.dir, "4-differential-expression"))

# get results
male_high.fat_vs_male_normal <- results(dds, 
                  alpha = 0.05, 
                  contrast = c("diet", "high.fat", "normal"))

# get a summary of the amount of significantly DEG 
summary(male_high.fat_vs_male_normal, 
        alpha = 0.05)

# get shrunken fold change
# male_high.fat_vs_male_normal <- lfcShrink(dds = dds,
#                               res = male_high.fat_vs_male_normal,
#                               contrast = c("condition", "no infect", "background"),
#                               type = "ashr")

cols <- c("ensembl_gene_id",
          "external_gene_name",
          "entrezgene_id",
          "gene_biotype",
          "chromosome_name",
          "start_position",
          "end_position",
          "percentage_gene_gc_content")

male_high.fat_vs_male_normal <- merge(as.data.frame(rowData(dds)[,cols]),
                         as.data.frame(male_high.fat_vs_male_normal),
                         by = "row.names")

counts <- counts(dds, normalized = TRUE)
colnames(counts) <- dds$sample.description
male_high.fat_vs_male_normal <- merge(male_high.fat_vs_male_normal, 
                         counts,
                         by.x = "Row.names",
                         by = "row.names")

male_high.fat_vs_male_normal$ensembl_gene_id <- NULL
colnames(male_high.fat_vs_male_normal)[1] <- "ensembl_gene_id"

# write results
write.csv(male_high.fat_vs_male_normal, "male_high.fat_vs_male_normal.csv",
          row.names = FALSE)

# p-value distribution histogram
pdf("male_high.fat_vs_male_normal_pvalue_distribution.pdf",
    width = 5,
    height = 5)
hist(male_high.fat_vs_male_normal$pvalue, 
     main = "Male High-Fat vs Male Normal", 
     xlab = "P-value", 
     ylab = "Frequency")
dev.off()


# ma plot
male_high.fat_vs_male_normal <- male_high.fat_vs_male_normal %>%
  as.data.frame() %>%
  mutate(sig = case_when(log2FoldChange > 0 & male_high.fat_vs_male_normal$padj < 0.05 ~ "Upregulated",
                         log2FoldChange < 0 & male_high.fat_vs_male_normal$padj < 0.05 ~ "Downregulated",
                         .default = "")
         )

