diet_sex_interaction_gsva_merge <- merge(male_high.fat_vs_male_normal_gsva,
                        female_high.fat_vs_female_normal_gsva[,c("logFC", "P.Value", "adj.P.Val")],
                        by = "row.names")
rownames(diet_sex_interaction_gsva_merge) <- diet_sex_interaction_gsva_merge$Row.names

diet_sex_interaction_gsva_merge <- merge(diet_sex_interaction_gsva_merge, 
                        diet_sex_interaction_gsva[,c("logFC", "P.Value", "adj.P.Val")],
                        by = "row.names")
rownames(diet_sex_interaction_gsva_merge) <- diet_sex_interaction_gsva_merge$Row.names
diet_sex_interaction_gsva_merge$Row.names <- NULL

# clean up columns
diet_sex_interaction_gsva_merge <- diet_sex_interaction_gsva_merge[c("pathway", "database",
                                   "logFC.x", "P.Value.x", "adj.P.Val.x",
                                   "logFC.y", "P.Value.y", "adj.P.Val.y",
                                   "logFC", "P.Value", "adj.P.Val")]

# rename columns
colnames(diet_sex_interaction_gsva_merge)[3:11] <- c("male_high.fat_vs_male_normal_gsva.logFC",
                                    "male_high.fat_vs_male_normal_gsva.P.Value",
                                    "male_high.fat_vs_male_normal_gsva.adj.P.Val",
                                    "female_high.fat_vs_female_normal_gsva.logFC",
                                    "female_high.fat_vs_female_normal_gsva.P.Value",
                                    "female_high.fat_vs_female_normal_gsva.adj.P.Val",
                                    "diet_sex_interaction_gsva_merge.logFC",
                                    "diet_sex_interaction_gsva_merge.P.Value",
                                    "diet_sex_interaction_gsva_merge.adj.P.Val")

fc_thr    <- 0.5
p_thr     <- 0.05
delta_thr <- 0.1

diet_sex_interaction_gsva_merge <- diet_sex_interaction_gsva_merge %>%
  mutate(
    x = male_high.fat_vs_male_normal_gsva.logFC,
    y = female_high.fat_vs_female_normal_gsva.logFC,
    delta = diet_sex_interaction_gsva_merge.logFC,
    quadrant = case_when(
      x > 0 & y > 0 ~ "Concordant Up",
      x < 0 & y < 0 ~ "Concordant Down",
      x > 0 & y < 0 ~ "Negative Reversal: Up -> Down",
      x < 0 & y > 0 ~ "Positive Reversal: Down -> Up",
      TRUE ~ "Near Zero / Mixed"
    ),
    modulation = case_when(
      quadrant == "Concordant Up"   & delta >  delta_thr ~ "Amplified Up",
      quadrant == "Concordant Up"   & delta < -delta_thr ~ "Attenuated Up",
      quadrant == "Concordant Down" & delta < -delta_thr ~ "Amplified Down",
      quadrant == "Concordant Down" & delta >  delta_thr ~ "Attenuated Down",
      TRUE ~ NA_character_
    ),
    sig_int = !is.na(diet_sex_interaction_gsva_merge.adj.P.Val) &
              diet_sex_interaction_gsva_merge.adj.P.Val < p_thr,
    sig_simple = ((abs(x) > fc_thr) & !is.na(male_high.fat_vs_male_normal_gsva.adj.P.Val) &
                   male_high.fat_vs_male_normal_gsva.adj.P.Val < p_thr) |
                 ((abs(y) > fc_thr) & !is.na(female_high.fat_vs_female_normal_gsva.adj.P.Val) &
                   female_high.fat_vs_female_normal_gsva.adj.P.Val < p_thr),
    Label = case_when(
      sig_int    ~ if_else(!is.na(modulation), modulation, quadrant),
      sig_simple ~ if_else(!is.na(modulation), modulation, quadrant),
      TRUE       ~ "Not Significant"
    )
  )

table(diet_sex_interaction_gsva_merge$modulation)

# output
write.csv(diet_sex_interaction_gsva_merge, "diet_sex_interaction_gsva_merge.csv", row.names = FALSE)

## ---- plot ----

# only significant-interaction genes
out <- diet_sex_interaction_gsva_merge %>%
  mutate(sig_int = !is.na(diet_sex_interaction_gsva_merge.adj.P.Val) &
                   diet_sex_interaction_gsva_merge.adj.P.Val < p_thr)
sig <- out %>% filter(sig_int)  

# label top genes by interaction padj
highlight <- out %>%
  filter(sig_int) %>%
  arrange(diet_sex_interaction_gsva_merge.adj.P.Val) %>%
  slice_head(n = 20)

pdf("diet_sex_interaction_gsva_merge_log2fc_corr.pdf", height = 4, width = 6)
ggplot() +
  # background: nonsignificant interaction genes
  geom_point(data = out, aes(x = x, y = y),
             color = "grey40", alpha = 0.1, size = 1, show.legend = FALSE) +
  geom_abline(slope = 1, intercept = 0, linetype = "dashed") +
  geom_vline(xintercept = 0, linetype = "dashed") +
  geom_hline(yintercept = 0, linetype = "dashed") +
  # overlay: only significant interaction genes are colored
 geom_point(data = sig, aes(x = x, y = y, color = Label),
             size = 2, alpha = 0.75) +
 geom_text_repel(
    data = highlight,
    aes(x = x, y = y, label = pathway),
    size = 2, fontface = "bold", colour = "black",
    segment.color = "black", segment.size = 0.3,
    box.padding = 0.4, point.padding = 0.3,
    max.overlaps = Inf, min.segment.length = 0
  ) +
  lims(x = c(-2, 2), y = c(-2, 2)) +
  scale_color_manual(
    name = "Interaction class",
    values = c(
    "Amplified Up"       = "firebrick",
    "Attenuated Up"      = "orange3",
    "Amplified Down"     = "navy",
    "Attenuated Down"    = "skyblue4",
    "Negative Reversal: Up -> Down"   = "purple",
    "Positive Reversal: Down -> Up"   = "darkgreen"
  ) # , drop = FALSE  # uncomment to keep all legend entries even if absent
  ) +
  guides(color = guide_legend(override.aes = list(alpha = 1, size = 2))) +
  theme_bw() + theme(panel.grid = element_blank()) +
  labs(x = "Effect of infection with DMSO (log2FC)",
       y = "Effect of infection with CIMSS (log2FC)",
       title = "Drug × Infection: Significant Interactions",
       subtitle = "Log2FC > 0.5; padj < 0.5",)
dev.off()
