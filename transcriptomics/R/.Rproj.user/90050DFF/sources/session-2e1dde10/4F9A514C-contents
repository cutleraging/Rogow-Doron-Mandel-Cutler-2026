## Pre-process
- Update to change all masses to modification annotation, e.g. ac, me, etc.
- Update to change the placement of N-term mods to be after the first AA

### Create modified peptide column
- This is used to match the MSFragger results to the spectral library
- Round the modification massess to the 2nd decimal place
```{r}
searchRes <- searchRes %>%
  rowwise() %>%
  mutate(
    ModifiedPeptideSequence = {
      chars <- str_split(peptide, "", simplify = FALSE)[[1]]
      mods  <- str_split(modification_info, ",\\s*", simplify = FALSE)[[1]]
      for (m in mods) {
        # internal site
        if (str_detect(m, "^\\d+")) {
          parts <- str_match(m, "(\\d+)[A-Za-z]\\(([^)]+)\\)")
          pos  <- as.integer(parts[2])
          mass <- round(as.numeric(parts[3]), 2)
          chars[pos] <- paste0(chars[pos], "(", mass, ")")
        }
        # N-terminus
        else if (str_detect(m, "^N-term")) {
          mass <- round(
            as.numeric(str_match(m, "N-term\\(([^)]+)\\)")[2]),
            2
          )
          chars[1] <- paste0("(", mass, ")", chars[1])
        }
        # C-terminus
        else if (str_detect(m, "^C-term")) {
          mass <- round(
            as.numeric(str_match(m, "C-term\\(([^)]+)\\)")[2]),
            2
          )
          last_pos <- length(chars)
          chars[last_pos] <- paste0(chars[last_pos], "(", mass, ")")
        }
      }
      paste0(chars, collapse = "")
    }
  ) %>%
  ungroup() %>%
  mutate(ModifiedPeptideSequence = str_replace(ModifiedPeptideSequence, "^\\.", "")) # remove any leading dot
```

### Replace Unimod ID with monoisotopic mass
```{r, eval = TRUE}
# define the XML namespace (inspect the root node to get its prefix/URI)
ns <- xml_ns(moddb)

# mass lookup
get_unimod_mass <- function(ids, xml, ns) {
  recs <- str_replace(ids, ".*?(\\d+).*", "\\1")
  sapply(recs, function(r) {
    mod_node   <- xml_find_first(xml, sprintf("//umod:mod[@record_id='%s']", r), ns)
    delta_node <- xml_find_first(mod_node, ".//umod:delta", ns)
    as.numeric(xml_attr(delta_node, "mono_mass"))
  }, USE.NAMES = FALSE)
}

# rowwise replace all tags
specLib <- specLib %>%
  rowwise() %>%
  mutate(
    ModifiedPeptideSequence = {
      seq0 <- ModifiedPeptideSequence
      # extract every "(UniMod:123)" occurrence
      tags <- str_extract_all(seq0, "\\(UniMod:\\d+\\)")[[1]]
      # for each tag, lookup & replace
      for(tag in unique(tags)) {
        id   <- str_extract(tag, "\\d+")
        mass <- round(get_unimod_mass(id, moddb, ns), 2)
        seq0 <- str_replace_all(seq0, fixed(tag), paste0("(", mass, ")"))
      }
      seq0
    }
  ) %>%
  ungroup()

# formating for modifications that were not converted to unimod
specLib <- specLib %>%
  mutate(
    ModifiedPeptideSequence = str_replace_all(
      ModifiedPeptideSequence,
      # match bracketed mass, e.g. “[126.06806]”
      "\\[([^\\]]+)\\]",
      # function(x) gets the full match “[126.06806]”
      function(x) {
        # remove brackets
        num <- as.numeric(str_remove_all(x, "\\[|\\]"))
        # round to 2 dp
        mass <- round(num, 2)
        # rebuild with parentheses
        paste0("(", mass, ")")
      }
    ) %>%
      str_replace("^\\.", "")  # then drop leading dot
  )
```

