modification_proportion <- specLib.chimaFilter %>%
  # 1) extract & unnest all mass tags
  mutate(masses = str_extract_all(
           ModifiedPeptideSequence,
           "(?<=\\()[0-9]+\\.?[0-9]*(?=\\))"
         )) %>%
  unnest(masses) %>%
  # 2) drop the unwanted masses
  filter(! masses %in% c("56.03", "112.05")) %>%
  # 3) map each mass to its modification name
  mutate(modification = recode(masses, !!!mass2mod)) %>%
  # 4) count how many times each modification occurs
  count(modification, name = "n_total") %>%
  # 5) compute proportions of the grand total
  mutate(prop = n_total / sum(n_total)) %>%
  arrange(desc(n_total))

write.csv(modification_proportion, "modification_proportion.csv",
          row.names = FALSE)

