### Replace modification masses with names
- This should be done at a later time so for now the N-term mods can still be distinguished 
```{r, eval = FALSE}
# 1) original high-precision map
orig_map <- c(
  "112.05243" = "n-term-pr",
  "98.036779" = "n-term-ac",
  "126.06808" = "n-term-me",
  "84.057515" = "n-term-me2",
  "98.073165" = "n-term-me3",
  "56.026215" = "pr",
  "42.010565" = "ac",
  "70.041865" = "me",
  "28.0313"   = "me2",
  "42.04695"  = "me3"
)

# 2) round the keys to 2 dp (they stay unique)
rounded_map <- setNames(
  orig_map,
  sprintf("%.2f", round(as.numeric(names(orig_map)), 2))
)

# 3) perform replacement with a lookup function
searchRes <- searchRes %>%
  mutate(
    ModifiedPeptideSequenceCharge = str_replace_all(
      ModifiedPeptideSequenceCharge,
      "\\(([0-9]+\\.?[0-9]*)\\)",
      function(match) {
        m   <- as.numeric(str_remove_all(match, "[()]"))
        key <- sprintf("%.2f", round(m, 2))
        if (key %in% names(rounded_map)) {
          paste0("[", rounded_map[[key]], "]")
        } else {
          paste0("(", key, ")")
        }
      }
    )
  ) 

specLib <- specLib %>%
  mutate(
    ModifiedPeptideSequenceCharge = str_replace_all(
      ModifiedPeptideSequenceCharge,
      "\\(([0-9]+\\.?[0-9]*)\\)",
      function(match) {
        m   <- as.numeric(str_remove_all(match, "[()]"))
        key <- sprintf("%.2f", round(m, 2))
        if (key %in% names(rounded_map)) {
          paste0("[", rounded_map[[key]], "]")
        } else {
          paste0("(", key, ")")
        }
      }
    )
  )
```

